@inherits LayoutComponentBase

<FluentLayout>
    <FluentLayoutItem Area="@LayoutArea.Header">
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentLayoutHamburger />
            <a href="/" style="text-decoration: none; color: inherit; display: flex; align-items: center;">
                <FluentText Weight="TextWeight.Bold" Size="TextSize.Size400">
                    Aspire Fluent UI Showcase
                </FluentText>
            </a>
        </FluentStack>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Navigation">
        <NavMenu />
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Content">
        @Body
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Footer">
        Powered by Microsoft Fluent UI Blazor V5 @DateTime.Now.Year
    </FluentLayoutItem>
</FluentLayout>

<FluentProviders />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
