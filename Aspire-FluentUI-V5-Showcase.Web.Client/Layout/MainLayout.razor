@inherits LayoutComponentBase

<FluentLayout Class="app-layout">
    <FluentLayoutItem Area="@LayoutArea.Header">
        <FluentStack VerticalAlignment="VerticalAlignment.Center" Style="padding: 0 1rem;">
            <FluentLayoutHamburger />
            <a href="/" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.5rem;">
                <FluentIcon Value="@(new Icons.Regular.Size24.Rocket())" Color="Color.Primary" />
                <FluentText Weight="TextWeight.Bold" Size="TextSize.Size400">
                    Aspire Showcase
                </FluentText>
            </a>
        </FluentStack>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Navigation">
        <NavMenu />
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Content">
        <div style="height: 100%; overflow: auto;">
            @Body
        </div>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Footer">
        <FluentDivider Style="margin-bottom: 0.5rem;" />
        <FluentStack HorizontalAlignment="HorizontalAlignment.Center">
            <FluentText Size="TextSize.Size300">
                Crafted with love using Fluent UI V5 • @DateTime.Now.Year
            </FluentText>
        </FluentStack>
    </FluentLayoutItem>
</FluentLayout>

<FluentProviders />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
