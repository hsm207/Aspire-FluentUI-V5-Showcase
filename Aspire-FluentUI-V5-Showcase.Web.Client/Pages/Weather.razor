@page "/weather"
@rendermode InteractiveAuto
@using Aspire_FluentUI_V5_Showcase.Web.Client.Models

<PageTitle>Weather</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
    <FluentText As="@TextTag.H1" Size="TextSize.Size700">Weather</FluentText>

    <FluentText>This component demonstrates showing data loaded from a backend API service.</FluentText>

    @if (_viewModel == null)
    {
        <FluentSpinner />
        <FluentText><em>Loading...</em></FluentText>
    }
    else
    {
        <div class="weather-grid-container">
            <FluentDataGrid Items="@_viewModel.Forecasts.AsQueryable()" TGridItem="WeatherForecast" ResizableColumns="true" ShowHover="true">
                <PropertyColumn Property="@(f => f.Date)" Title="Date" Format="yyyy-MM-dd" Sortable="true" Align="DataGridCellAlignment.Start" />
                <PropertyColumn Property="@(f => f.TemperatureC)" Title="Temp. (C)" Sortable="true" Align="DataGridCellAlignment.End" />
                <PropertyColumn Property="@(f => f.TemperatureF)" Title="Temp. (F)" Sortable="true" Align="DataGridCellAlignment.End" />
                <PropertyColumn Property="@(f => f.Summary)" Title="Summary" Align="DataGridCellAlignment.Start" />
            </FluentDataGrid>
        </div>
    }
</FluentStack>
