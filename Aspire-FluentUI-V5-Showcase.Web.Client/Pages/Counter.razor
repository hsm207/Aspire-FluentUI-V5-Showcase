@page "/counter"

<PageTitle>Counter</PageTitle>

<div class="counter-container">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
        <FluentText As="@TextTag.H1" Size="TextSize.Size700">Counter</FluentText>

        <FluentLabel role="status">Current count: @ViewModel.CurrentCount</FluentLabel>

        <FluentButton Appearance="ButtonAppearance.Primary" 
                      OnClick="IncrementCountAsync"
                      IconStart="@(new Icons.Regular.Size20.Add())">
            Click me
        </FluentButton>
    </FluentStack>
</div>
